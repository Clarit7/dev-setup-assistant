# ──────────────────────────────────────────────────────────────────────────────
# 개발환경 세팅 도우미 — LLM 설정 파일
# 이 파일을 .env 로 복사한 뒤 사용할 API 키를 입력하세요.
# ──────────────────────────────────────────────────────────────────────────────

# 사용할 LLM 프로바이더 선택 (anthropic | openai | gemini | ollama)
LLM_PROVIDER=anthropic

# ── Anthropic Claude (추천) ───────────────────────────────────────────────────
# 회원가입: https://console.anthropic.com
# 첫 가입 시 $5 크레딧 제공 / 이후 사용량 기반 과금
# Haiku 기준 대화 1회 약 $0.001
ANTHROPIC_API_KEY=sk-ant-여기에_발급받은_키를_입력하세요

# ── OpenAI GPT (대안) ─────────────────────────────────────────────────────────
# 회원가입: https://platform.openai.com
# 카드 등록 후 사용량 과금 / gpt-4o-mini 기준 매우 저렴
# OPENAI_API_KEY=sk-여기에_발급받은_키를_입력하세요

# ── Google Gemini (무료 시작) ─────────────────────────────────────────────────
# 회원가입: https://aistudio.google.com (Google 계정)
# Gemini Flash: 무료 티어 있음 (분당 15회 요청)
# GEMINI_API_KEY=AIza여기에_발급받은_키를_입력하세요

# ── Ollama (로컬, 무료) ────────────────────────────────────────────────────────
# 설치: https://ollama.ai  →  ollama pull mistral
# API 키 불필요 / LLM_PROVIDER=ollama 로 변경
# OLLAMA_BASE_URL=http://localhost:11434

# ── 모델 오버라이드 (선택 사항) ───────────────────────────────────────────────
# 기본값: claude-haiku-4-5-20251001 / gpt-4o-mini / gemini-1.5-flash / mistral
# LLM_MODEL=claude-sonnet-4-6
